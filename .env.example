# ── Русский стек (Timeweb/Selectel + Yandex Object Storage) ──

# ── Локальная разработка без PostgreSQL ──
# Если DATABASE_URL не задан, сайт читает товары из Supabase (ключи ниже).
# На сервере (VPS) DATABASE_URL обязателен.

# Админка
ADMIN_PASSWORD=admin1234

# ── Уведомления клиентам: Telegram, VK, WhatsApp, MAX ──
# Пока токены не заданы — отправка пропускается (status: skipped в notification_log).

# Публичный URL сайта (для ссылок в ботах и webhook)
NEXT_PUBLIC_SITE_URL=https://testletto.ru

# Telegram Bot API — https://t.me/BotFather
# На VPS в РФ api.telegram.org часто заблокирован — используйте Cloudflare Worker (deploy/telegram-proxy)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Группа флористов: переписка с клиентами (ответ реплаем). Можно тот же id, что и ADMIN.
TELEGRAM_SUPPORT_GROUP_ID=
TELEGRAM_WEBHOOK_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# Прокси к Bot API (URL Cloudflare Worker / Vercel), пусто = напрямую api.telegram.org
TELEGRAM_API_BASE_URL=
TELEGRAM_PROXY_KEY=
# Обход блокировки на VPS в РФ: GitHub Actions relay (см. .github/workflows/telegram-relay.yml)
GITHUB_TELEGRAM_RELAY_TOKEN=
GITHUB_TELEGRAM_RELAY_REPO=MatveiShadchin/letto

# ВКонтакте Callback API — тестовая группа https://vk.com/club240024216
# Управление → Настройки → Работа с API → Callback API
# URL: https://testletto.ru/api/webhooks/vk
# События: входящее сообщение (message_new)
VK_GROUP_ID=240024216
NEXT_PUBLIC_VK_GROUP_ID=240024216
NEXT_PUBLIC_VK_URL=https://vk.com/club240024216
VK_GROUP_TOKEN=
VK_CONFIRMATION_CODE=
VK_WEBHOOK_SECRET=
VK_ADMIN_USER_ID=

# WhatsApp Business (Meta Cloud API или WHATSAPP_API_URL провайдера)
WHATSAPP_PROVIDER=meta
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# MAX Bot API — https://dev.max.ru (нужна верификация ИП/самозанятого)
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api2.max.ru
MAX_WEBHOOK_SECRET=
NEXT_PUBLIC_MAX_BOT_USERNAME=

# PostgreSQL на VPS
# DATABASE_URL=postgresql://letto:PASSWORD@127.0.0.1:5432/letto

# Yandex Object Storage (S3-совместимое)
YANDEX_STORAGE_ACCESS_KEY=
YANDEX_STORAGE_SECRET_KEY=
YANDEX_STORAGE_BUCKET=letto-products
YANDEX_STORAGE_REGION=ru-central1
YANDEX_STORAGE_ENDPOINT=https://storage.yandexcloud.net

# Публичный URL бакета (для картинок на сайте)
NEXT_PUBLIC_STORAGE_PUBLIC_URL=https://storage.yandexcloud.net/letto-products

# ── Старый Supabase (можно удалить после миграции) ──
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SECRET_KEY=
